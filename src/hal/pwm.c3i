module arduino::pwm;

<*
 Supported PWM pins on ATmega328P / Arduino Uno.
*>
constdef PWMPin {
	D3  = 3,
	D5  = 5,
	D6  = 6,
	D9  = 9,
	D10 = 10,
	D11 = 11,
}

const char MAX_DUTY = 0xFF;
const char MIN_DUTY = 0x00; 

<*
 Set the duty cycle for a PWM pin.
 @param pin : `The PWM pin to set.`
 @param duty : `The duty cycle (0-255).`
*>
macro void analog_write(PWMPin pin, char duty) => analog_write_impl(pin, duty);

