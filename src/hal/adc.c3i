module arduino::adc;

import arduino::gpio;

// analog_read accepts only AnalogPin values (A0-A5).
// The compiler resolves unqualified 'A0' etc. to AnalogPin.A0
// when passed to this function.
// Returns a 10-bit value in the range 0-1023.
macro ushort analog_read(AnalogPin pin) => analog_read_impl(pin);

